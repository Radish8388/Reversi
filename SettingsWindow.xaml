<Window x:Class="Reversi.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Reversi"
        mc:Ignorable="d"
        Title="SettingsWindow"
        Height="310" Width="310"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="30,20,0,0" TextWrapping="Wrap" Text="Player Color" FontSize="24" VerticalAlignment="Top"/>
        <RadioButton x:Name="Black" Content="Black" GroupName="Color" HorizontalAlignment="Left" Margin="30,55,0,0" VerticalAlignment="Top" FontSize="20"/>
        <RadioButton x:Name="White" Content="White" GroupName="Color" HorizontalAlignment="Left" Margin="110,55,0,0" VerticalAlignment="Top" FontSize="20"/>

        <TextBlock HorizontalAlignment="Left" Margin="30,90,0,0" TextWrapping="Wrap" Text="Highlight Moves" FontSize="24" VerticalAlignment="Top"/>
        <RadioButton x:Name="MovesYes" Content="Yes" GroupName="Moves" HorizontalAlignment="Left" Margin="30,125,0,0" VerticalAlignment="Top" FontSize="20"/>
        <RadioButton x:Name="MovesNo" Content="No" GroupName="Moves" HorizontalAlignment="Left" Margin="110,125,0,0" VerticalAlignment="Top" FontSize="20"/>

        <TextBlock HorizontalAlignment="Left" Margin="30,160,0,0" TextWrapping="Wrap" Text="Difficulty" FontSize="24" VerticalAlignment="Top"/>
        <RadioButton x:Name="Easy" Content="Easy" GroupName="Difficulty" HorizontalAlignment="Left" Margin="30,195,0,0" VerticalAlignment="Top" FontSize="20"/>
        <RadioButton x:Name="Medium" Content="Medium" GroupName="Difficulty" HorizontalAlignment="Left" Margin="110,195,0,0" VerticalAlignment="Top" FontSize="20"/>
        <RadioButton x:Name="Hard" Content="Hard" GroupName="Difficulty" HorizontalAlignment="Left" Margin="225,195,0,0" VerticalAlignment="Top" FontSize="20"/>

        <Button Name="okButton" Content="OK" IsDefault="True" HorizontalAlignment="Left" Margin="30,240,0,0" VerticalAlignment="Top" Click="okButton_Click" Width="50"/>
        <Button Name="cancelButton" Content="Cancel" IsCancel="True" HorizontalAlignment="Left" Margin="100,240,0,0" VerticalAlignment="Top" Click="cancelButton_Click" Width="50"/>

    </Grid>
</Window>
