<Window x:Class="Reversi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Reversi"
        mc:Ignorable="d"
        Title="Reversi"
        SizeChanged="Window_SizeChanged"
        Loaded="Window_Loaded"
        Height="750" Width="678">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/> <!-- Buttons and scores -->
            <RowDefinition Height="*"/>  <!-- Game area -->
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="YOU" VerticalAlignment="Center" FontSize="24" Margin="10"/>
            <Ellipse x:Name="YourColor" Width="35" Height="35" Fill="Black" Stroke="Black" StrokeThickness="1"/>
            <TextBlock x:Name="YourScore" Text="02" VerticalAlignment="Center" FontSize="24" Margin="10"/>
            <Button x:Name="NewGameButton" Content="New Game" Width="70" Margin="10" Click="NewGame_Click"/>
            <Button x:Name='SettingsButton' Content="Settings" Width="70" Margin="10" Click="Settings_Click"/>
            <TextBlock Text="COMPUTER" VerticalAlignment="Center" FontSize="24" Margin="10"/>
            <Ellipse x:Name="MyColor" Width="35" Height="35" Fill="White" Stroke="Black" StrokeThickness="1"/>
            <TextBlock x:Name="MyScore" Text="02" VerticalAlignment="Center" FontSize="24" Margin="10"/>
        </StackPanel>
        <Canvas x:Name="gameCanvas" Background="ForestGreen" Grid.Row="1"
                PreviewMouseDown="gameCanvas_PreviewMouseDown"/>
    </Grid>
</Window>
